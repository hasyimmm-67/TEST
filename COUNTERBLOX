-- Skin apply function
local function applySkinToTool(tool)
    if not tool then return false end
    local skinData = skColors[sci]
    local c1 = skinData[2]
    local c2 = skinData[3]
    local count = 0
    for _, part in ipairs(tool:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "Handle" then
            part.Color = c1
            local mesh = part:FindFirstChildOfClass("SpecialMesh")
            if mesh then
                mesh.TextureId = "rbxassetid://14418045086"
                mesh.VertexColor = Vector3.new(c2.R, c2.G, c2.B)
            end
            count = count + 1
        end
        if part:IsA("Decal") then
            part.Texture = "rbxassetid://14418045086"
        end
    end
    return count > 0
end

applyBtn.MouseButton1Click:Connect(function()
    local c = lp.Character
    if not c then skStat.Text = "✗ No character" return end
    local tool = c:FindFirstChildOfClass("Tool")
    if not tool then
        -- Try to find weapon in backpack
        local bp = lp:FindFirstChild("Backpack")
        if bp then tool = bp:FindFirstChildOfClass("Tool") end
    end
    if tool then
        local ok = applySkinToTool(tool)
        skStat.Text = ok and "✓ Applied " .. skColors[sci][1] .. " to " .. tool.Name or "✗ No parts found"
    else
        -- Apply to viewmodel
        local vm = rep:FindFirstChild("WeaponsViewmodels")
        if vm then
            local vmtool = vm:FindFirstChild("v_" .. wl[wi])
            if vmtool then
                local ok = applySkinToTool(vmtool)
                skStat.Text = ok and "✓ Applied " .. skColors[sci][1] .. " to " .. wl[wi] or "✗ No parts in viewmodel"
            else
                skStat.Text = "✗ Viewmodel " .. wl[wi] .. " not found"
            end
        else
            skStat.Text = "✗ No weapons found — use tool in hand"
        end
    end
end)

