--=== AIMBOT CORE ===--
local function isVisible(p)
    local c = p.Character
    if not c then return false end
    local r = c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso")
    if not r then return false end
    local dir = (r.Position - ca.CFrame.Position).Unit
    local dist = (r.Position - ca.CFrame.Position).Magnitude
    local ray = Ray.new(ca.CFrame.Position, dir * dist)
    local hit, pos = ws:FindPartOnRayWithIgnoreList(ray, { lp.Character })
    return hit and hit:IsDescendantOf(c.Character)
end

local function checkTeam(p)
    if not tg["Team Check"] then return true end
    return p.Team ~= lp.Team
end

local function getHitPos(p)
    local c = p.Character
    if not c then return nil end
    -- Hitbox selection
    local parts = { "HumanoidRootPart", "Torso", "Head" }
    local hitIdx = math.min(math.floor(hbFn()), #parts)
    local pname = parts[hitIdx]
    local r = c:FindFirstChild(pname)
    if not r then
        r = c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso")
    end
    return r and r.Position
end

local function w2s(pos)
    local v, on = ca:WorldToViewportPoint(pos)
    return Vector2.new(v.X, v.Y), on
end

local function findTarget()
    local closest = nil
    local cd = fovFn()
    local mp = Vector2.new(m.X, m.Y)
    for _, p in ipairs(P:GetPlayers()) do
        if p == lp then continue end
        if not checkTeam(p) then continue end
        if tg["Visible Check"] and not isVisible(p) then continue end
        local tp = getHitPos(p)
        if not tp then continue end
        local sp, on = w2s(tp)
        if not on then continue end
        local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
        if d < cd then
            cd = d
            closest = p
        end
    end
    return closest
end

