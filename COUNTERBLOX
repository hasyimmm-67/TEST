local function addToggle(parent, label, def)
    tg[label] = def
    local fr = Instance.new("Frame", parent)
    fr.Size = UDim2.new(1, -8, 0, 32)
    fr.BackgroundTransparency = 1

    local lb = Instance.new("TextLabel", fr)
    lb.Size = UDim2.new(0.65, 0, 1, 0)
    lb.BackgroundTransparency = 1
    lb.Text = label
    lb.TextColor3 = Color3.fromRGB(200, 200, 210)
    lb.Font = Enum.Font.SourceSans
    lb.TextSize = 15
    lb.TextXAlignment = Enum.TextXAlignment.Left

    local btn = Instance.new("TextButton", fr)
    btn.Size = UDim2.new(0, 46, 0, 22)
    btn.Position = UDim2.new(0.88, -23, 0.5, -11)
    btn.BackgroundColor3 = def and Color3.fromRGB(160, 20, 20) or Color3.fromRGB(40, 40, 50)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Text = def and "ON" or "OFF"
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 13
    btn.AutoButtonColor = false
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 3)

    btn.MouseButton1Click:Connect(function()
        tg[label] = not tg[label]
        local s = tg[label]
        btn.BackgroundColor3 = s and Color3.fromRGB(160, 20, 20) or Color3.fromRGB(40, 40, 50)
        btn.Text = s and "ON" or "OFF"
    end)
end

local function addSlider(parent, label, min, max, def)
    local val = def
    local fr = Instance.new("Frame", parent)
    fr.Size = UDim2.new(1, -8, 0, 48)
    fr.BackgroundTransparency = 1

    local lb = Instance.new("TextLabel", fr)
    lb.Size = UDim2.new(0.5, 0, 0, 18)
    lb.BackgroundTransparency = 1
    lb.Text = label .. ": " .. def
    lb.TextColor3 = Color3.fromRGB(200, 200, 210)
    lb.Font = Enum.Font.SourceSans
    lb.TextSize = 14
    lb.TextXAlignment = Enum.TextXAlignment.Left

    local bb = Instance.new("Frame", fr)
    bb.Size = UDim2.new(0.85, 0, 0, 4)
    bb.Position = UDim2.new(0.1, 0, 0, 28)
    bb.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    bb.BorderSizePixel = 0
    Instance.new("UICorner", bb).CornerRadius = UDim.new(0, 2)

    local bf = Instance.new("Frame", bb)
    bf.Size = UDim2.new((def - min) / (max - min), 0, 1, 0)
    bf.BackgroundColor3 = Color3.fromRGB(160, 20, 20)
    bf.BorderSizePixel = 0
    Instance.new("UICorner", bf).CornerRadius = UDim.new(0, 2)

    local db = Instance.new("TextButton", bb)
    db.Size = UDim2.new(0, 14, 0, 14)
    db.Position = UDim2.new(bf.Size.X.Scale, -7, 0, -5)
    db.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
    db.BorderSizePixel = 0
    db.Text = ""
    Instance.new("UICorner", db).CornerRadius = UDim.new(0, 7)

    local dragging = false
    db.MouseButton1Down:Connect(function() dragging = true end)
    U.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    U.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local pct = math.clamp((m.X - bb.AbsolutePosition.X) / bb.AbsoluteSize.X, 0, 1)
            bf.Size = UDim2.new(pct, 0, 1, 0)
            db.Position = UDim2.new(pct, -7, 0, -5)
            val = math.floor(min + (max - min) * pct)
            lb.Text = label .. ": " .. val
        end
    end)
    return function() return val end
end

